# Gemini Cloud Run Relay - Environment Variables Example
#
# Copy this file to `.env` and fill in real values.
# IMPORTANT: Do NOT commit the real `.env` file to GitHub.

# ==============================
# Required
# ==============================

# Cloud Run relay base URL (no trailing slash)
GEMINI_RELAY_BASE_URL=https://<YOUR_CLOUD_RUN_DOMAIN>/v1

# API key for relay authentication
GEMINI_RELAY_API_KEY=<YOUR_API_KEY>

# ==============================
# Optional / Advanced
# ==============================

# Request timeout (seconds)
GEMINI_RELAY_TIMEOUT=120

# Max retries on network errors
GEMINI_RELAY_MAX_RETRIES=2

# ==============================
# Notes
# ==============================
# - Keep this file public-safe (example only)
# - Real secrets must live in `.env` or system env vars
# - Typical usage:
#     export $(cat .env | xargs)
#   or load via your runtime (Node/Python/Docker)
